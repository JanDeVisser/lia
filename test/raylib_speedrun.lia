import raylib

export func main() i32 {
    raylib.InitWindow(800::i32, 600::i32, `Lia Speedrun`)
    raylib.SetTargetFPS(60::i32);
    while (!raylib.WindowShouldClose()) {
        raylib.BeginDrawing()
        raylib.ClearBackground(raylib.RED)
        raylib.EndDrawing()
    }
    raylib.CloseWindow()
    return 0::i32
}

